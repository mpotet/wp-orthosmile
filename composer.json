{
    "name": "mpotet/wp-orthosmile",
    "description": "Theme WordPress premium pour cabinets d'orthodontie et cliniques dentaires.",
    "type": "wordpress-theme",
    "license": "GPL-2.0-or-later",
    "require-dev": {
        "phpunit/phpunit": "^10"
    },
    "autoload-dev": {
        "psr-4": {
            "OrthoSmile\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {}
    }
}
